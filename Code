#include <driver/ledc.h>

// =====================================================
// MOTOR PINS
// =====================================================

#define IN1 4
#define IN2 5
#define IN3 6
#define IN4 7

// =====================================================
// PWM CONFIGURATION
// =====================================================

#define LEDC_TIMER          LEDC_TIMER_0
#define LEDC_MODE           LEDC_LOW_SPEED_MODE
#define LEDC_FREQUENCY      300
#define LEDC_RESOLUTION     LEDC_TIMER_8_BIT

#define CH_IN1              LEDC_CHANNEL_0
#define CH_IN2              LEDC_CHANNEL_1
#define CH_IN3              LEDC_CHANNEL_2
#define CH_IN4              LEDC_CHANNEL_3

// =====================================================
// SPEED SETTINGS
// =====================================================

// Optimized for 3.7V / 7.4V mini RC car

#define FULL_SPEED 140
#define TURN_SLOW 15

char command;

// =====================================================
// MOVEMENT STATE
// =====================================================

bool movingForward = true;

// =====================================================
// PWM INIT
// =====================================================

void initPWM()
{
  ledc_timer_config_t timer = {
    .speed_mode = LEDC_MODE,
    .duty_resolution = LEDC_RESOLUTION,
    .timer_num = LEDC_TIMER,
    .freq_hz = LEDC_FREQUENCY,
    .clk_cfg = LEDC_AUTO_CLK
  };

  ledc_timer_config(&timer);

  ledc_channel_config_t channels[4] = {

    {
      .gpio_num = IN1,
      .speed_mode = LEDC_MODE,
      .channel = CH_IN1,
      .intr_type = LEDC_INTR_DISABLE,
      .timer_sel = LEDC_TIMER,
      .duty = 0,
      .hpoint = 0
    },

    {
      .gpio_num = IN2,
      .speed_mode = LEDC_MODE,
      .channel = CH_IN2,
      .intr_type = LEDC_INTR_DISABLE,
      .timer_sel = LEDC_TIMER,
      .duty = 0,
      .hpoint = 0
    },

    {
      .gpio_num = IN3,
      .speed_mode = LEDC_MODE,
      .channel = CH_IN3,
      .intr_type = LEDC_INTR_DISABLE,
      .timer_sel = LEDC_TIMER,
      .duty = 0,
      .hpoint = 0
    },

    {
      .gpio_num = IN4,
      .speed_mode = LEDC_MODE,
      .channel = CH_IN4,
      .intr_type = LEDC_INTR_DISABLE,
      .timer_sel = LEDC_TIMER,
      .duty = 0,
      .hpoint = 0
    }

  };

  for(int i = 0; i < 4; i++)
  {
    ledc_channel_config(&channels[i]);
  }
}

// =====================================================
// LEFT MOTOR
// =====================================================

void setLeftMotor(int speed)
{
  if(speed > 0)
  {
    // Forward

    ledc_set_duty(LEDC_MODE, CH_IN1, speed);
    ledc_update_duty(LEDC_MODE, CH_IN1);

    ledc_set_duty(LEDC_MODE, CH_IN2, 0);
    ledc_update_duty(LEDC_MODE, CH_IN2);
  }

  else if(speed < 0)
  {
    // Backward

    ledc_set_duty(LEDC_MODE, CH_IN1, 0);
    ledc_update_duty(LEDC_MODE, CH_IN1);

    ledc_set_duty(LEDC_MODE, CH_IN2, -speed);
    ledc_update_duty(LEDC_MODE, CH_IN2);
  }

  else
  {
    // Stop

    ledc_set_duty(LEDC_MODE, CH_IN1, 0);
    ledc_update_duty(LEDC_MODE, CH_IN1);

    ledc_set_duty(LEDC_MODE, CH_IN2, 0);
    ledc_update_duty(LEDC_MODE, CH_IN2);
  }
}

// =====================================================
// RIGHT MOTOR (REVERSED)
// =====================================================

void setRightMotor(int speed)
{
  if(speed > 0)
  {
    // Forward (Reversed Motor)

    ledc_set_duty(LEDC_MODE, CH_IN3, 0);
    ledc_update_duty(LEDC_MODE, CH_IN3);

    ledc_set_duty(LEDC_MODE, CH_IN4, speed);
    ledc_update_duty(LEDC_MODE, CH_IN4);
  }

  else if(speed < 0)
  {
    // Backward (Reversed Motor)

    ledc_set_duty(LEDC_MODE, CH_IN3, -speed);
    ledc_update_duty(LEDC_MODE, CH_IN3);

    ledc_set_duty(LEDC_MODE, CH_IN4, 0);
    ledc_update_duty(LEDC_MODE, CH_IN4);
  }

  else
  {
    // Stop

    ledc_set_duty(LEDC_MODE, CH_IN3, 0);
    ledc_update_duty(LEDC_MODE, CH_IN3);

    ledc_set_duty(LEDC_MODE, CH_IN4, 0);
    ledc_update_duty(LEDC_MODE, CH_IN4);
  }
}

// =====================================================
// STOP
// =====================================================

void stopCar()
{
  setLeftMotor(0);
  setRightMotor(0);

  Serial.println("STOP");
}

// =====================================================
// FORWARD
// =====================================================

void moveForward()
{
  movingForward = true;

  setLeftMotor(FULL_SPEED);
  setRightMotor(FULL_SPEED);

  Serial.println("FORWARD");
}

// =====================================================
// BACKWARD
// =====================================================

void moveBackward()
{
  movingForward = false;

  setLeftMotor(-FULL_SPEED);
  setRightMotor(-FULL_SPEED);

  Serial.println("BACKWARD");
}

// =====================================================
// LEFT TURN
// =====================================================

void turnLeft()
{
  if(movingForward)
  {
    // Forward Left Turn

    setLeftMotor(TURN_SLOW);
    setRightMotor(FULL_SPEED);

    Serial.println("FORWARD LEFT");
  }

  else
  {
    // Backward Left Turn

    setLeftMotor(-TURN_SLOW);
    setRightMotor(-FULL_SPEED);

    Serial.println("BACKWARD LEFT");
  }
}

// =====================================================
// RIGHT TURN
// =====================================================

void turnRight()
{
  if(movingForward)
  {
    // Forward Right Turn

    setLeftMotor(FULL_SPEED);
    setRightMotor(TURN_SLOW);

    Serial.println("FORWARD RIGHT");
  }

  else
  {
    // Backward Right Turn

    setLeftMotor(-FULL_SPEED);
    setRightMotor(-TURN_SLOW);

    Serial.println("BACKWARD RIGHT");
  }
}

// =====================================================
// SETUP
// =====================================================

void setup()
{
  Serial.begin(115200);

  // Motor Pins

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);

  // FORCE STOP AT BOOT

  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);

  delay(500);

  // Bluetooth HC05

  Serial1.begin(9600, SERIAL_8N1, 20, 21);

  // PWM Init

  initPWM();

  // Stop Motors

  stopCar();

  Serial.println("================================");
  Serial.println("ESP32-C3 RC CAR READY");
  Serial.println("HC05 CONNECTED");
  Serial.println("SMART TURNING ENABLED");
  Serial.println("================================");
}

// =====================================================
// LOOP
// =====================================================

void loop()
{
  if(Serial1.available())
  {
    command = Serial1.read();

    Serial.print("CMD: ");
    Serial.println(command);

    // =============================================
    // FORWARD
    // =============================================

    if(command == 'F')
    {
      moveForward();
    }

    // =============================================
    // BACKWARD
    // =============================================

    else if(command == 'B')
    {
      moveBackward();
    }

    // =============================================
    // LEFT
    // =============================================

    else if(command == 'L')
    {
      turnLeft();
    }

    // =============================================
    // RIGHT
    // =============================================

    else if(command == 'R')
    {
      turnRight();
    }

    // =============================================
    // STOP
    // =============================================

    else if(command == 'S')
    {
      stopCar();
    }
  }
}
